# Raincloud environment template
# Copy to .env for local development. Do not commit real secrets.

# Azure identity used by deployment scripts or local cloud smoke tests.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure resource names for the MVP cloud dispatch loop.
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_QUEUE_NAME=approved-worker-runs
AZURE_INPUTS_CONTAINER_NAME=inputs
AZURE_OUTPUTS_CONTAINER_NAME=outputs
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_HERMES_JOB_NAME=

# Raincloud API and worker callback configuration.
RAINCLOUD_API_URL=http://localhost:3000
RAINCLOUD_WORKER_CALLBACK_SECRET=

# Model provider key for planner and natural-language reorder behavior.
OPENAI_API_KEY=

# Supabase is optional for the earliest local worker smoke tests,
# but should back the first durable task store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
