# Raincloud environment template
# Copy to .env for local development. Do not commit real secrets.

# Azure identity used by deployment scripts or local cloud smoke tests.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure resource names for the MVP cloud dispatch loop.
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_QUEUE_NAME=approved-worker-runs
AZURE_INPUTS_CONTAINER_NAME=inputs
AZURE_OUTPUTS_CONTAINER_NAME=outputs
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_HERMES_JOB_NAME=

# Raincloud API and worker callback configuration.
# For local E2E with the Azure worker, start `ngrok http 3000` before approving.
# You may set this to the current HTTPS tunnel URL. If left as localhost, the API
# will try to auto-detect the active ngrok tunnel from http://127.0.0.1:4040.
# Explicit public URLs must answer GET /health before approval queues a worker.
# The worker runs in Azure Container Apps and cannot reach localhost directly.
# Example: RAINCLOUD_API_URL=https://xyz.ngrok-free.app
RAINCLOUD_API_URL=http://localhost:3000

# Mobile app base URL. Use your LAN IP on a physical device (not localhost).
# Example: EXPO_PUBLIC_RAINCLOUD_API_URL=http://192.168.1.100:3000
EXPO_PUBLIC_RAINCLOUD_API_URL=http://localhost:3000

RAINCLOUD_WORKER_CALLBACK_SECRET=
RAINCLOUD_WORKER_SMOKE_CALLBACK_URL=https://httpbingo.org/status/202
RAINCLOUD_WORKER_SMOKE_CALLBACK_SECRET=raincloud-smoke-callback-secret

# Model provider key for planner and natural-language reorder behavior.
OPENAI_API_KEY=
RAINCLOUD_OPENAI_MODEL=gpt-5.4-mini

# Supabase is optional for the earliest local worker smoke tests,
# but should back the first durable task store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
